RewriteRule ^club$ club_news-46425 [L,R=301,QSD]
RewriteCond %{QUERY_STRING} ^news=46401$
RewriteRule ^club$ club_news-46401 [L,R=301,QSD]
RewriteCond %{QUERY_STRING} ^news=46367$
RewriteRule ^club$ club_news-46367 [L,R=301,QSD]
RewriteCond %{QUERY_STRING} ^id=46360$
RewriteRule ^announcement$ announcement_id-46360 [L,R=301,QSD]
RewriteCond %{QUERY_STRING} ^id=46320$
RewriteRule ^announcement$ announcement_id-46320 [L,R=301,QSD]
RewriteCond %{QUERY_STRING} ^id=46304$
RewriteRule ^announcement$ announcement_id-46304 [L,R=301,QSD]
RewriteCond %{QUERY_STRING} ^news=46439$
RewriteRule ^club$ club_news-46439 [L,R=301,QSD]
RewriteCond %{QUERY_STRING} ^news=46437$
RewriteRule ^club$ club_news-46437 [L,R=301,QSD]
