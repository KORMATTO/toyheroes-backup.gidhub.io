RewriteRule ^club$ club_news-46416 [L,R=301,QSD]
RewriteCond %{QUERY_STRING} ^news=46440$
RewriteRule ^club$ club_news-46440 [L,R=301,QSD]
RewriteCond %{QUERY_STRING} ^news=46438$
RewriteRule ^club$ club_news-46438 [L,R=301,QSD]
RewriteCond %{QUERY_STRING} ^news=46435$
RewriteRule ^club$ club_news-46435 [L,R=301,QSD]
RewriteCond %{QUERY_STRING} ^news=46433$
RewriteRule ^club$ club_news-46433 [L,R=301,QSD]
RewriteCond %{QUERY_STRING} ^news=46430$
RewriteRule ^club$ club_news-46430 [L,R=301,QSD]
RewriteCond %{QUERY_STRING} ^news=46426$
RewriteRule ^club$ club_news-46426 [L,R=301,QSD]
